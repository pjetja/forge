# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-NEVER-EXPOSE-TO-BROWSER

# Site URL — set to http://localhost:3000 locally; set to https://[your-app].vercel.app in Vercel dashboard
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (Drizzle migrations — use Supabase connection string)
# Supabase Dashboard → Project Settings → Database → Connection string → URI (Transaction mode)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Demo users (for seed:demo script)
DEMO_TRAINER_EMAIL=demo.trainer@forge.app
DEMO_TRAINER_PASSWORD=ForgeDemo2026!
DEMO_TRAINEE_EMAIL=demo.trainee@forge.app
DEMO_TRAINEE_PASSWORD=ForgeDemo2026!
